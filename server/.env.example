# ───────────────────────────────────────────────────────────
# KanbanBoard auth-service
# Copy to .env and fill in for your environment.
# ───────────────────────────────────────────────────────────

# Mode switch — one of: ldap | oidc | local
AUTH_MODE=ldap

# Server
PORT=4000
NODE_ENV=development
# Long random string — generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-value
# Where the SPA lives. Used for OIDC post-login redirect.
APP_BASE_URL=http://localhost:5173

# ─── LDAP mode (on-prem AD DS) ─────────────────────────────
# LDAPS strongly recommended. Plain ldap:// is rejected in production.
LDAP_URL=ldaps://dc.corp.example:636
# Use {{username}} placeholder. Common templates:
#   uid={{username}},ou=users,dc=corp,dc=example       (generic)
#   {{username}}@corp.example                          (AD UPN — userPrincipalName)
#   CORP\{{username}}                                  (AD down-level name)
LDAP_BIND_DN_TEMPLATE={{username}}@corp.example
LDAP_SEARCH_BASE=dc=corp,dc=example
LDAP_SEARCH_FILTER=(|(sAMAccountName={{username}})(userPrincipalName={{username}}))
# JSON map: AD group DN → app role. First match wins.
LDAP_ROLE_MAP={"CN=Kanban-Admins,OU=Groups,DC=corp,DC=example":"Admin","CN=Kanban-Editors,OU=Groups,DC=corp,DC=example":"Editor"}
# Default role if no group matches
LDAP_DEFAULT_ROLE=Viewer

# ─── OIDC mode (Entra ID) ──────────────────────────────────
OIDC_TENANT_ID=00000000-0000-0000-0000-000000000000
OIDC_CLIENT_ID=00000000-0000-0000-0000-000000000000
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URI=http://localhost:5173/auth/callback
# Optional: JSON map of Entra app-role values → app role.
OIDC_ROLE_MAP={"KanbanAdmin":"Admin","KanbanEditor":"Editor"}
OIDC_DEFAULT_ROLE=Viewer

# ─── Local mode ────────────────────────────────────────────
# File-backed user store with bcrypt-hashed passwords. Managed via
# `npm run user:add|remove|list|reset`. First-run seeding below.
LOCAL_USERS_PATH=./data/users.json
# Set BOTH to seed a single Admin on first boot when the store is empty.
# Remove after first successful start — they are only read when users.json
# is empty or missing.
# BOOTSTRAP_ADMIN_USER=admin
# BOOTSTRAP_ADMIN_PASSWORD=change-me-at-least-8-chars

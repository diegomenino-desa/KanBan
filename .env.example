# Copy this file to .env and fill in real values before running docker compose.
# .env is gitignored — never commit real secrets.

# Required: a long random string used to sign session cookies.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-secret

# The public URL users reach the app at (used in OIDC redirect URIs).
APP_BASE_URL=http://localhost:8102

# ── LDAP mode (AUTH_MODE=ldap) ────────────────────────────────────────────────
LDAP_URL=ldaps://dc.corp.example:636
LDAP_BIND_DN_TEMPLATE={{username}}@corp.example
LDAP_SEARCH_BASE=DC=corp,DC=example
#LDAP_SEARCH_FILTER=(|(sAMAccountName={{username}})(userPrincipalName={{username}}))
#LDAP_ROLE_MAP={"CN=Kanban-Admins,OU=Groups,DC=corp,DC=example":"Admin"}
#LDAP_DEFAULT_ROLE=Viewer

# Self-signed / internal CA: provide the PEM file path (mounted into the container).
#LDAP_TLS_CA_CERT_PATH=/app/certs/ldap-ca.pem
# Last-resort only — disables cert verification entirely (not recommended).
#LDAP_TLS_REJECT_UNAUTHORIZED=false
# Allow plaintext ldap:// in production (demo servers only — never in real AD).
#LDAP_ALLOW_PLAINTEXT=true

# ── OIDC mode (AUTH_MODE=oidc) ────────────────────────────────────────────────
#OIDC_TENANT_ID=
#OIDC_CLIENT_ID=
#OIDC_CLIENT_SECRET=
